# Example environment variables (DO NOT commit real keys here)
# Set these in your environment or in Vercel project settings.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key
SUPABASE_STORAGE_BUCKET=competition-images
APP_URL=https://your-vercel-domain.vercel.app
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx

# For local development you can export before running:
# export SUPABASE_URL=...
# export SUPABASE_KEY=...
# export SUPABASE_STORAGE_BUCKET=...
# export PAYSTACK_SECRET_KEY=...
# export PAYSTACK_PUBLIC_KEY=...
